---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SAE.STUDIO | Entorno Premium de Etiquetado Térmico">
  <!-- Interactive Background Mesh -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 bg-main overflow-hidden">
    <div class="absolute top-[20%] left-[20%] w-[500px] h-[500px] bg-emerald-500/10 rounded-full blur-[120px] mix-blend-screen animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-[20%] right-[10%] w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[150px] mix-blend-screen pointer-events-none" style="animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite reverse;"></div>
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-20 brightness-100 contrast-150 mix-blend-overlay pointer-events-none"></div>
  </div>

  <main class="relative pt-24 pb-16 lg:pt-36 w-full max-w-7xl mx-auto px-6 h-full flex flex-col justify-between min-h-screen">
    
    <!-- Navbar / Header area -->
    <header class="absolute top-0 left-0 w-full flex justify-between items-center px-6 py-6 lg:px-12 z-50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-[0_0_20px_rgba(16,185,129,0.4)] flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </div>
        <span class="text-xl font-bold tracking-tight text-white drop-shadow-sm">SAE.<span class="text-emerald-400">STUDIO</span></span>
      </div>
      <div>
        <a href="https://github.com/EskenderDev/SAE.STUDIO.APP" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-300 hover:text-white transition-colors flex items-center gap-2 bg-white/5 hover:bg-white/10 px-4 py-2 rounded-full border border-white/5 backdrop-blur-md">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
          GitHub
        </a>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="flex flex-col items-center text-center mt-12 mb-24 lg:mb-32 z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        Nuevo: Windows Service Integrado
      </div>
      
      <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-200 to-slate-400 mb-6 drop-shadow-sm max-w-4xl">
        Infraestructura Profesional para <br class="hidden sm:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">Etiquetas y Tickets</span>
      </h1>
      
      <p class="text-lg lg:text-xl text-slate-400 max-w-2xl mb-12 leading-relaxed">
        El motor definitivo para el diseño e impresión de etiquetas industriales y tickets de punto de venta. Crea plantillas dinámicas visualmente e imprímelas desde tu aplicación escritorio o móvil a través de nuestra API local.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full">
        <!-- Contenedor manejado por React/JS lado cliente para el botón dinámico -->
        <div id="download-button-container" class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg blur opacity-25 group-hover:opacity-60 transition duration-1000 group-hover:duration-200"></div>
          <button disabled class="relative flex items-center gap-3 px-8 py-4 bg-slate-900 border border-slate-700/50 rounded-lg text-white font-semibold shadow-2xl transition-all cursor-wait">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-emerald-500" xmlns="https://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            Cargando última versión...
          </button>
        </div>
        
        <a href="/docs" class="px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-white font-semibold shadow-lg transition-all backdrop-blur-md">
          Ver Documentación
        </a>
      </div>
      <p id="release-info" class="text-sm text-slate-500 mt-4 opacity-0 transition-opacity duration-500 font-mono"></p>
    </section>

    <!-- Features Section -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24 z-10">
      <div class="glass p-8 rounded-2xl border-t border-white/10 hover:bg-white/[0.03] transition-colors group">
        <div class="w-12 h-12 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Diseñador de Etiquetas</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Interfaz drag-and-drop intuitiva para etiquetas de producto. Soporte nativo para EAN13, QR y Code128 con previsualización real.
        </p>
      </div>

      <div class="glass p-8 rounded-2xl border-t border-white/10 hover:bg-white/[0.03] transition-colors group">
        <div class="w-12 h-12 bg-orange-500/20 text-orange-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Editor de Tickets</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Diseño optimizado para rollos continuos. Genera recibos térmicos profesionales con logotipos, tablas de precios y pies de página dinámicos.
        </p>
      </div>

      <div class="glass p-8 rounded-2xl border-t border-white/10 hover:bg-white/[0.03] transition-colors group">
        <div class="w-12 h-12 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">API Local (REST)</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Motor Windows Service en segundo plano. Envía un POST desde tu software de ventas y la impresora térmica disparará al momento.
        </p>
      </div>

      <div class="glass p-8 rounded-2xl border-t border-white/10 hover:bg-white/[0.03] transition-colors group">
        <div class="w-12 h-12 bg-purple-500/20 text-purple-400 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Tauri Updater</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Actualizaciones automáticas y seguras integradas. Tus clientes siempre tendrán la última versión del motor de impresión.
        </p>
      </div>
    </section>

    <!-- Footer with MIT License -->
    <footer class="mt-auto border-t border-white/10 pt-8 pb-8 z-10 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-slate-500 text-sm text-center md:text-left">
        <p>&copy; {new Date().getFullYear()} EskenderDev. - SAE System All rights reserved.</p>
        <p class="mt-1">
          Released under the <a href="https://github.com/EskenderDev/SAE.STUDIO.APP/blob/master/LICENSE" target="_blank" class="text-emerald-400 hover:underline">MIT License</a>.
        </p>
      </div>
      <div class="flex items-center gap-6">
        <span class="text-slate-600 text-sm font-medium">Arquitectura: Tauri + Astro + C# .NET</span>
      </div>
    </footer>
  </main>

  <!-- Client-side script to fetch latest GitHub release -->
  <script>
    async function fetchLatestRelease() {
      const container = document.getElementById('download-button-container');
      const infoText = document.getElementById('release-info');
      
      if (!container || !infoText) return;

      try {
        const response = await fetch('https://api.github.com/repos/EskenderDev/SAE.STUDIO.APP/releases/latest');
        
        if (!response.ok) {
          throw new Error('No se pudo obtener la última versión');
        }
        
        const data = await response.json();
        
        // Find the .exe or .msi asset
        const installerAsset = data.assets.find((a: any) => 
          a.name.endsWith('.exe') || a.name.endsWith('.msi')
        );

        const version = data.tag_name;
        
        if (installerAsset) {
          container.innerHTML = `
            <div class="absolute -inset-1 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-lg blur opacity-25 group-hover:opacity-60 transition duration-1000 group-hover:duration-200"></div>
            <a href="${installerAsset.browser_download_url}" class="relative flex items-center justify-center gap-3 px-8 py-4 bg-emerald-600 hover:bg-emerald-500 border border-emerald-400/50 rounded-lg text-white font-bold shadow-2xl shadow-emerald-900/50 transition-all text-lg w-full">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="https://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              Descargar para Windows
            </a>
          `;
          infoText.textContent = `Versión actual: ${version} • ${Math.round(installerAsset.size / 1024 / 1024)} MB`;
        } else {
           container.innerHTML = `
            <a href="https://github.com/EskenderDev/SAE.STUDIO.APP/releases/latest" target="_blank" class="relative flex items-center justify-center gap-3 px-8 py-4 bg-slate-800 hover:bg-slate-700 border border-slate-600 rounded-lg text-white font-semibold transition-all">
              Ver Releases en GitHub
            </a>
          `;
          infoText.textContent = `Versión actual: ${version}`;
        }
        
        infoText.classList.remove('opacity-0');
        
      } catch (error) {
        console.error('Error fetching release:', error);
        container.innerHTML = `
          <a href="https://github.com/EskenderDev/SAE.STUDIO.APP/releases" target="_blank" class="relative flex items-center justify-center gap-3 px-8 py-4 bg-slate-800 hover:bg-slate-700 border border-slate-600 rounded-lg text-white font-semibold transition-all">
            Descargar desde GitHub
          </a>
        `;
      }
    }

    // Execute on mount
    fetchLatestRelease();
  </script>
</Layout>
