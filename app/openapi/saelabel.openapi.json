    "/api/labels/parse": {
      "post": {
        "tags": [
          "Labels"
        ],
        "summary": "Parsea un documento .saelabels",
        "description": "Recibe XML SAELABEL y responde el documento estructurado en JSON.\n\n**Request example**\n```json\n{ \"xml\": \"<saelabels version=\\\"1.0\\\"><template brand=\\\"SAE\\\" description=\\\"Demo\\\" part=\\\"P-1\\\" size=\\\"custom\\\"><label_rectangle width_pt=\\\"144\\\" height_pt=\\\"72\\\" round_pt=\\\"0\\\" x_waste_pt=\\\"0\\\" y_waste_pt=\\\"0\\\" /><layout dx_pt=\\\"0\\\" dy_pt=\\\"0\\\" nx=\\\"1\\\" ny=\\\"1\\\" x0_pt=\\\"0\\\" y0_pt=\\\"0\\\" /></template><objects /><variables /></saelabels>\" }\n```",
        "operationId": "ParseSaeLabels",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SaeLabelsDocument"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SaeLabelsDocument"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SaeLabelsDocument"
                }
              }
            }
          }
        }
      }
    },
    "/api/labels/convert-from-glabels": {
      "post": {
        "tags": [
          "Labels"
        ],
        "summary": "Convierte XML glabels a .saelabels",
        "description": "Toma un XML con estructura glabels y devuelve XML SAELABEL normalizado.\n\n**Request example**\n```json\n{ \"xml\": \"<Glabels-document><Template brand=\\\"Avery\\\" description=\\\"Mailing\\\" part=\\\"8160\\\" size=\\\"US-Letter\\\"><Label-rectangle width=\\\"189pt\\\" height=\\\"72pt\\\" round=\\\"0pt\\\"><Layout dx=\\\"200pt\\\" dy=\\\"72pt\\\" nx=\\\"3\\\" ny=\\\"10\\\" x0=\\\"11.25pt\\\" y0=\\\"36pt\\\" /></Label-rectangle></Template><Objects /><Variables /></Glabels-document>\" }\n```",
        "operationId": "ConvertFromGlabels",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/XmlPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
