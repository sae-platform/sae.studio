<saetickets version="1.0">
  <setup width="48"/>
  <commands>
    <text align="center" bold="true" size="large">SAE POS</text>
    <text align="center" bold="true" size="medium">COMANDA</text>
    <separator char="-"/>
    <text>Mesa: ${MESA}</text>
    <text>Pax: ${PAX}</text>
    <text>Hora: ${!TIME} ${!DATE}</text>
    <separator char="-"/>
    <each listVar="ITEMS" header="true">
      <column field="CANTIDAD" label="Cant" width="5" align="right"/>
      <column field="NOMBRE" label="Item" width="auto"/>
      <column field="TOTAL" label="Total" width="12" align="right"/>
    </each>
    <separator char="-"/>
    <total label="TOTAL" value="${TOTAL}" bold="true" align="right"/>
    <feed lines="2"/>
    <cut/>
  </commands>
</saetickets>
