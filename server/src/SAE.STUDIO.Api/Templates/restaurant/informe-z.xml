<saetickets version="1.0">
  <setup width="48"/>
  <commands>
    <text align="center" bold="true" size="large">SAE POS</text>
    <text align="center" bold="true" size="medium">INFORME Z #${NUMERO}</text>
    <text align="center" bold="true">CIERRE DEFINITIVO</text>
    <separator char="="/>
    <text>Caja: ${CAJA}</text>
    <text>Cajero: ${CAJERO}</text>
    <text>Fecha: ${!DATE} ${!TIME}</text>
    <separator char="-"/>
    <text bold="true" align="center">RESUMEN DIARIO</text>
    <separator char="-"/>
    <total label="Apertura" value="${APERTURA}" align="left"/>
    <total label="Ventas" value="${VENTAS}" align="left"/>
    <total label="Facturas" value="${FACTURAS}" align="left"/>
    <separator char="-"/>
    <text bold="true" align="center">ARQUEO</text>
    <separator char="-"/>
    <total label="Esperado" value="${ESPERADO}" align="left"/>
    <total label="Contado" value="${CONTADO}" align="left"/>
    <total label="Diferencia" value="${DIFERENCIA}" bold="true" align="left"/>
    <separator char="-"/>
    <if expr="SOBRANTE">
      <text align="center" bold="true">SOBRANTE</text>
    </if>
    <if expr="FALTANTE">
      <text align="center" bold="true">FALTANTE</text>
    </if>
    <if expr="CUADRADO">
      <text align="center" bold="true">CUADRADO</text>
    </if>
    <separator char="="/>
    <feed lines="3"/>
    <cut/>
  </commands>
</saetickets>
