<saedocument version="1.0">
  <setup pageSize="A4" marginTop="15mm" marginBottom="15mm" marginLeft="15mm" marginRight="15mm"/>
  <header>
    <text size="20" bold="true" align="center">${!EMPRESA}</text>
    <spacer height="5"/>
    <line/>
    <spacer height="3"/>
    <text size="16" bold="true" align="center">CONTRATO DE SERVICIOS</text>
    <text size="10" align="center">#${NUMERO}</text>
    <spacer height="10"/>
  </header>
  <body>
    <text size="10" bold="true">Entre:</text>
    <text size="10">${!EMPRESA}, cédula jurídica ${!NIT}, representada por ${REPRESENTANTE}</text>
    <spacer height="5"/>
    <text size="10" bold="true">Y:</text>
    <text size="10">${CLIENTE_NOMBRE}, cédula ${CLIENTE_CEDULA}</text>
    <spacer height="5"/>
    <text size="10" bold="true">Objeto del contrato:</text>
    <text size="9">${OBJETO}</text>
    <spacer height="5"/>
    <text size="10" bold="true">Condiciones:</text>
    <text size="9">${CONDICIONES}</text>
    <spacer height="5"/>
    <text size="10" bold="true">Monto:</text>
    <text size="10">${MONTO}</text>
    <spacer height="5"/>
    <text size="10" bold="true">Vigencia:</text>
    <text size="9">Desde ${FECHA_INICIO} hasta ${FECHA_FIN}</text>
    <spacer height="10"/>
    <text size="10" bold="true" align="center">Firmas</text>
    <spacer height="20"/>
    <table source="FIRMAS" showHeader="false">
      <column field="PARTE" header="" width="*" align="center"/>
      <column field="FIRMA" header="" width="*" align="center"/>
    </table>
  </body>
  <footer>
    <spacer height="30"/>
    <line/>
    <text size="7" align="center">Documento generado el ${!DATE} ${!TIME}</text>
  </footer>
</saedocument>
